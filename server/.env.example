# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
# Local (Docker Compose) — host port 5433 to avoid clashing with a local Postgres on 5432:
DATABASE_URL=postgres://surya:surya@localhost:5433/surya_store
# Production (Neon) — replace with your pooled connection string:
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.neon.tech/db?sslmode=require

# ── Auth (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Seed admin (created by `npm run seed`) ──────────────
ADMIN_EMAIL=admin@suryastore.com
ADMIN_PASSWORD=Admin@123

# ── Cloudinary (image uploads) — optional in dev ────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── New-order alerts: Telegram (recommended — free & reliable) ──
# Setup:
#   1. In Telegram, message @BotFather → send /newbot → pick a name + username.
#      BotFather replies with a BOT TOKEN like 123456:AA... → that's TELEGRAM_BOT_TOKEN.
#   2. Open your new bot (tap its t.me link) and press Start / send any message.
#   3. Get your chat id: open this URL in a browser (paste your token):
#         https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find  "chat":{"id":123456789 ...}  → that number is TELEGRAM_CHAT_ID.
#      (Tip: add the bot to a group and use the group's id to alert multiple staff.)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (SMTP) for OTP verification & password reset ──
# Free option: Brevo (sendinblue) — 300 emails/day. Create an account →
# SMTP & API → generate an SMTP key. Gmail also works with an App Password.
# In development, if these are blank the OTP is printed to the server console.
SMTP_HOST=            # e.g. smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=            # your SMTP login
SMTP_PASS=            # your SMTP key/password
SMTP_FROM=            # e.g. Surya Store <no-reply@yourdomain.com>
