# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
# Local (Docker Compose) — host port 5433 to avoid clashing with a local Postgres on 5432:
DATABASE_URL=postgres://surya:surya@localhost:5433/surya_store
# Production (Neon) — replace with your pooled connection string:
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.neon.tech/db?sslmode=require

# ── Auth (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Seed admin (created by `npm run seed`) ──────────────
ADMIN_EMAIL=admin@suryastore.com
ADMIN_PASSWORD=Admin@123

# ── Cloudinary (image uploads) — optional in dev ────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── New-order alerts: Telegram (recommended — free & reliable) ──
# Setup:
#   1. In Telegram, message @BotFather → send /newbot → pick a name + username.
#      BotFather replies with a BOT TOKEN like 123456:AA... → that's TELEGRAM_BOT_TOKEN.
#   2. Open your new bot (tap its t.me link) and press Start / send any message.
#   3. Get your chat id: open this URL in a browser (paste your token):
#         https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find  "chat":{"id":123456789 ...}  → that number is TELEGRAM_CHAT_ID.
#      (Tip: add the bot to a group and use the group's id to alert multiple staff.)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (Brevo HTTP API) for OTP verification & password reset ──
# Works both locally and on cloud hosts (Render, etc.) — sends over HTTPS.
#   1. Sign up at brevo.com (free 300 emails/day)
#   2. Verify your sender email (Settings → Senders)
#   3. Settings → SMTP & API → API Keys → create a key (starts with xkeysib-)
# If BREVO_API_KEY is blank in development, the OTP is printed to the console.
BREVO_API_KEY=
MAIL_FROM=            # e.g. Surya Store <suryastorenoreply@gmail.com>  (a verified Brevo sender)
# OTP send limit per email within 8h. 0 = unlimited (dev). Set to 3 before production launch.
OTP_MAX_PER_WINDOW=0

# --- Address autocomplete / geocoding: Ola Maps (India-accurate, POI support) ---
#   1. Sign up (free) at https://maps.olakrutrim.com/
#   2. Create a project → generate an API Key
# If OLA_MAPS_API_KEY is blank, the address form still works with manual entry
# (autocomplete + "use my current location" are simply disabled).
OLA_MAPS_API_KEY=
